<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
	<metadata minClientVersion="3.4.4">
		<id>pCloud</id>
		<version>1.3.0</version>
		<authors>const.me</authors>
		<owners>const.me</owners>
		<summary>Unofficial SDK for https://pcloud.com/ cloud storage</summary>
		<description>A straightforward implementation of the binary protocol documented at https://docs.pcloud.com/</description>
		<copyright>Copyright © const.me, 2019-2026</copyright>
		<title>Unofficial SDK for https://pcloud.com/ cloud storage</title>
		<releaseNotes>
			Updated after pcloud.com API change that broke login and logout methods of this library.
			Seems pcloud.com no longer using auth tokens for TCP connections. Not wrong because unlike HTTP, the connections are stateful. However, at the time of this release the official API documentation has not yet been updated to reflect this change.
		</releaseNotes>
		<projectUrl>https://github.com/Const-me/pCloud</projectUrl>
		<repository type="git" url="https://github.com/Const-me/pCloud.git" />
		<license type="expression">MIT</license>
		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<dependencies>
			<group targetFramework="net10.0" />
			<group targetFramework="net48">
				<dependency id="System.Buffers" version="4.6.1" />
			</group>
		</dependencies>
		<tags>cloud</tags>
		<readme>docs\readme.md</readme>
	</metadata>
	<files>
		<!-- .NET 10 -->
		<file src="bin\Release\pCloud.dll" target="lib\net10.0" />
		<file src="bin\Release\pCloud.pdb" target="lib\net10.0" />
		<file src="bin\Release\pCloud.xml" target="lib\net10.0" />

		<!-- .NET 4.8 -->
		<file src="..\pCloudDesktop\bin\Release\pCloud.dll" target="lib\net48" />
		<file src="..\pCloudDesktop\bin\Release\pCloud.pdb" target="lib\net48" />
		<file src="..\pCloudDesktop\bin\Release\pCloud.xml" target="lib\net48" />

		<file src="readme.md" target="docs\" />
	</files>
</package>